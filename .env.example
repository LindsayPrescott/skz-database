# PostgreSQL — used by docker-compose to create the database
POSTGRES_USER=skz_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=skz_db

# SQLAlchemy / Alembic connection string
# Use host=db when running inside Docker, host=localhost when running scrapers/Alembic locally
DATABASE_URL=postgresql://skz_user:changeme@db:5432/skz_db

# Spotify API — register at https://developer.spotify.com
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# YouTube Data API v3 — enable at https://console.cloud.google.com (free: 10,000 units/day)
YOUTUBE_API_KEY=your_api_key_here
